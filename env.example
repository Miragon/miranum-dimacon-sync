# ───────────────────────────────────────────────────────────────────────────
# miranum-dimacon-sync — env template
#
# Copy to `.env` and fill in. `.env` is gitignored. dotenv loads `.env` at
# server boot and *augments* the process env — values already set in the
# environment (e.g. `fly secrets`) are NOT overwritten.
# ───────────────────────────────────────────────────────────────────────────

PORT=3020


# ─── ClockIn ──────────────────────────────────────────────────────────────
CLOCKIN_API_TOKEN=
# CLOCKIN_BASE_URL=    # optional override


# ─── Dimacon ──────────────────────────────────────────────────────────────
DIMACON_BASE_URL=
DIMACON_TENANT=
DIMACON_API_TOKEN=


# ─── Lexoffice ────────────────────────────────────────────────────────────
LEXWARE_OFFICE_API_KEY=
# LEXWARE_OFFICE_BASE_URL=    # optional override


# ─── Sync ─────────────────────────────────────────────────────────────────
# Scheduler is configured via the UI (/settings) and persisted in
# SETTINGS_PATH. The two SYNC_* vars below are only used as a one-time
# seed when the settings file does not yet exist.
SETTINGS_PATH=./data/settings.json
# SYNC_CRON="0 6 * * *"
# SYNC_TZ="Europe/Berlin"

# Shared secret for the POST /api/sync/run webhook (service-to-service).
# Leave empty to allow unauthenticated webhook calls in dev.
# SYNC_WEBHOOK_SECRET=


# ─── WorkOS Authentication ────────────────────────────────────────────────
# Public client — no API key needed in this app. The same client ID is
# consumed by both the SPA (VITE_*, baked into the bundle at build time)
# and the Hono backend (read at runtime, used to fetch the JWKS).

# Client ID from the WorkOS dashboard (starts with `client_`)
WORKOS_CLIENT_ID=
VITE_WORKOS_CLIENT_ID=

# Org that is allowed to use this app — backend rejects tokens whose
# `org_id` claim does not match. Starts with `org_`.
WORKOS_REQUIRED_ORG_ID=

# Your AuthKit Domain (no protocol). The SPA uses this instead of
# api.workos.com for the OAuth flow — ensures the request goes to the
# right WorkOS environment (e.g. staging vs production). Find it in the
# WorkOS dashboard under Authentication. Example:
#   sure-pulse-87-staging.authkit.app
VITE_WORKOS_API_HOSTNAME=

# Redirect URIs + allowed origins are configured in the WorkOS dashboard,
# not here. For dev add `http://localhost:3000`; for prod the deployed URL.
